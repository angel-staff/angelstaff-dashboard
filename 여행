 {d:"M385,112 Q335,168 285,232 Q245,288 238,318 Q248,352 300,382",n:"평화로"},
 {d:"M405,110 Q470,142 550,178 Q630,212 698,246",n:"번영로"},
 {d:"M398,114 Q392,190 382,252 Q372,300 361,330 Q350,372 345,398",n:"1100도로"},
 {d:"M412,112 Q450,180 468,240 Q464,310 442,368",n:"5·16도로"}
];
/* 오름·산: [x, y, 크기, 이름(옵션)] */
const HILLS=[
 [429,262,30,"한라산"],[280,232,10,"새별오름"],[205,278,9,""],[245,393,11,"산방산"],
 [680,158,8,"다랑쉬"],[855,160,9,""],[560,150,7,""],[620,290,7,""],[500,330,7,""],
 [160,300,6,""],[740,200,7,""]
];
/* 지역 라벨 */
const TOWNS=[[392,88,"제주시"],[150,205,"한림"],[205,138,"애월"],[315,425,"중문"],[445,385,"서귀포"],[858,142,"성산"],[705,258,"표선"],[190,345,"안덕"]];

const DAYS={
 1:{c:'#3d7a5c',title:'DAY 1 · 서부 코스',cap:'공항 → 협재 → 금오름 → 숙소 · 57km',
    route:['공항','제갈양','협재해수욕장','한림공원','금오름','숙소'],
    labels:{공항:['공항',0,-14],제갈양:['제갈양',-30,4],협재해수욕장:['협재',-26,-6],한림공원:['한림공원',34,14],금오름:['금오름',34,4],숙소:['숙소',18,16]},
    legend:['제갈양(점심)','협재해수욕장','한림공원','금오름(노을)','숙소 체크인']},
 2:{c:'#c05f2b',title:'DAY 2 · 남부 코스',cap:'오설록 → 중문 → 1100도로 · 56km',
    route:['숙소','오설록','카멜리아힐','고집돌우럭','주상절리','천제연','거린사슴','숙소'],
    labels:{숙소:['숙소',0,-13],오설록:['오설록',-30,10],카멜리아힐:['카멜리아힐',10,-13],고집돌우럭:['고집돌우럭',-44,2],주상절리:['주상절리',30,12],천제연:['천제연',-32,10],거린사슴:['거린사슴',36,-4]},
    legend:['오설록','카멜리아힐','고집돌우럭(점심)','주상절리','천제연(선택)','거린사슴전망대']},
 3:{c:'#0e5e6f',title:'DAY 3 · 동부 코스',cap:'섬 횡단 → 성산 → 표선 · 150km',
    route:['숙소','온더스톤','성산일출봉','광치기','타쿠마스시','아쿠아플라넷','로컬크랩','숙소'],
    labels:{숙소:['숙소',-22,4],온더스톤:['온더스톤',-38,-4],성산일출봉:['일출봉',22,-8],광치기:['광치기',-32,6],타쿠마스시:['타쿠마',-34,8],아쿠아플라넷:['아쿠아플라넷',20,14],로컬크랩:['로컬크랩',0,20]},
    legend:['온더스톤(브런치)','성산일출봉','광치기해변','타쿠마스시(점심)','아쿠아플라넷·섭지코지','로컬크랩(저녁)']},
 4:{c:'#6d5a9e',title:'DAY 4 · 귀가 코스',cap:'애월 → 이호테우 → 공항 · 47km',
    route:['숙소','애월한담','이호테우','공항'],
    labels:{숙소:['숙소',20,10],애월한담:['한담',-24,-4],이호테우:['이호테우',-6,-13],공항:['공항',20,10]},
    legend:['애월 한담 카페거리','이호테우 목마등대','렌터카 반납 → 공항']}
};

function hill(x,y,s,name){
  let g=`<path d="M${x-s},${y+s*0.55} Q${x-s*0.4},${y-s*0.5} ${x},${y-s*0.62} Q${x+s*0.4},${y-s*0.5} ${x+s},${y+s*0.55}" fill="none" stroke="#a9bbb4" stroke-width="1.6" stroke-linecap="round"/>
  <path d="M${x-s*0.45},${y+s*0.2} Q${x},${y-s*0.15} ${x+s*0.45},${y+s*0.2}" fill="none" stroke="#bccbc5" stroke-width="1.1" stroke-linecap="round"/>`;
  if(name) g+=`<text x="${x}" y="${y+s+11}" text-anchor="middle" font-size="9.5" fill="#93a49d">${name}</text>`;
  return g;
}

function buildMap(day){
  const D=DAYS[day], c=D.c;
  const pts=D.route.map(k=>S[k]);
  /* 해당 일차 영역으로 뷰 크롭 */
  let xs=pts.map(p=>p[0]),ys=pts.map(p=>p[1]);
  let x0=Math.min(...xs),x1=Math.max(...xs),y0=Math.min(...ys),y1=Math.max(...ys);
  const padX=Math.max((x1-x0)*0.35,70), padY=Math.max((y1-y0)*0.35,70);
  x0-=padX;x1+=padX;y0-=padY;y1+=padY;
  /* 화면비 4:3 보정 */
  let w=x1-x0,h=y1-y0;
  if(w/h<4/3.2){const nw=h*4/3.2;x0-=(nw-w)/2;w=nw;} else {const nh=w*3.2/4;y0-=(nh-h)/2;h=nh;}
  const vb=`${x0.toFixed(0)} ${y0.toFixed(0)} ${w.toFixed(0)} ${h.toFixed(0)}`;
  const sc=Math.sqrt(w*h)/380; /* 요소 스케일 */

  const poly=pts.map(p=>p.join(',')).join(' ');
  let dots='',n=1;
  D.route.forEach((k,i)=>{
    const [x,y]=S[k], lb=D.labels[k], isEnd=(k==='공항'||k==='숙소');
    const r=9*sc, fs=10*sc, lfs=11*sc;
    if(isEnd){
      const s2=6*sc;
      dots+=`<rect x="${x-s2}" y="${y-s2}" width="${s2*2}" height="${s2*2}" rx="${s2*0.5}" fill="#171c22"/>`;
      if(lb&&(i===0||i===D.route.length-1)) dots+=`<text x="${x+lb[1]}" y="${y+lb[2]}" text-anchor="middle" font-size="${lfs}" font-weight="700" fill="#171c22">${lb[0]}</text>`;
    }else{
      dots+=`<circle cx="${x}" cy="${y}" r="${r}" fill="${c}" stroke="#fff" stroke-width="${2*sc}"/><text x="${x}" y="${y+fs*0.36}" text-anchor="middle" font-size="${fs}" font-weight="800" fill="#fff">${n}</text>`;
      if(lb) dots+=`<text x="${x+lb[1]}" y="${y+lb[2]}" text-anchor="middle" font-size="${lfs}" font-weight="600" fill="#3d454e">${lb[0]}</text>`;
      n++;
    }
  });

  const roads=ROADS.map(r=>`<path d="${r.d}" fill="none" stroke="#c9d4cf" stroke-width="${2.2*sc}" stroke-linecap="round"/><path d="${r.d}" fill="none" stroke="#fff" stroke-width="${0.8*sc}" stroke-dasharray="${4*sc} ${5*sc}" stroke-linecap="round" opacity=".9"/>`).join('');
  const hills=HILLS.map(h2=>hill(h2[0],h2[1],h2[2]*Math.max(sc,.8),h2[3])).join('');
  const towns=TOWNS.map(t=>`<text x="${t[0]}" y="${t[1]}" text-anchor="middle" font-size="${10.5*sc}" font-weight="700" fill="#7d8f88" letter-spacing="1">${t[2]}</text>`).join('');

  /* 미니 전도 (우상단 인셋) */
  const inset=`<g transform="translate(${x1-150*sc},${y0+14*sc}) scale(${0.16*sc})">
    <path d="${ISLAND}" fill="#fff" stroke="#b8c6c0" stroke-width="6"/>
    <rect x="${x0}" y="${y0}" width="${w}" height="${h}" fill="none" stroke="${c}" stroke-width="10" rx="14"/>
  </g>`;

  return `
  <h5>${D.title}</h5><div class="mcap">${D.cap}</div>
  <svg viewBox="${vb}" xmlns="http://www.w3.org/2000/svg" style="background:linear-gradient(160deg,#e9f1f4,#f2f6f3)">
    <path d="${ISLAND}" fill="#eef3f0" stroke="#b8c6c0" stroke-width="${2*sc}"/>
    <path d="${ISLAND}" fill="none" stroke="#d7e2dd" stroke-width="${6*sc}" opacity=".5"/>
    ${roads}
    ${hills}
    ${towns}
    <polyline points="${poly}" fill="none" stroke="#fff" stroke-width="${6.5*sc}" stroke-linecap="round" stroke-linejoin="round" opacity=".8"/>
    <polyline points="${poly}" fill="none" stroke="${c}" stroke-width="${3.4*sc}" stroke-dasharray="${9*sc} ${6*sc}" stroke-linecap="round" stroke-linejoin="round"/>
    ${dots}
    ${inset}
  </svg>
  <div class="mlegend">${D.legend.map((l,i)=>`<span><i style="background:${c}">${i+1}</i>${l}</span>`).join('')}</div>`;
}
document.querySelectorAll('.mapbox').forEach(m=>{ m.innerHTML=buildMap(+m.dataset.day); });
</script>
